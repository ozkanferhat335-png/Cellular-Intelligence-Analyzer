<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      throwExceptions="false"
      internalLogLevel="Off">

  <targets>
    <target xsi:type="File"
            name="file"
            fileName="${specialfolder:folder=ApplicationData}/CellularIntelligenceAnalyzer/Logs/CIA_${shortdate}.log"
            layout="${longdate} | ${level:uppercase=true:padding=5} | ${logger:shortName=true} | ${message} ${exception:format=tostring}"
            archiveEvery="Day"
            maxArchiveFiles="90"
            encoding="utf-8" />

    <target xsi:type="Console"
            name="console"
            layout="${time} | ${level:uppercase=true} | ${message}" />
  </targets>

  <rules>
    <logger name="*" minlevel="Info" writeTo="file" />
    <logger name="*" minlevel="Debug" writeTo="console" />
  </rules>
</nlog>
